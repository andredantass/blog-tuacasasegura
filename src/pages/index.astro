---
import BaseLayout from '@/layouts/BaseLayout.astro'
import TitlePage from '@/components/TitlePage.astro'
import ListPosts from '@/components/ListPosts.astro'
import ListCategories from '@/components/ListCategories.astro'
import { siteConfig } from '@/data/site.config'
import directus from '@/lib/directus'
import { readItems, readSingleton } from '@directus/sdk'

const MAX_POSTS = 6

const [global, posts] = await Promise.all([
  directus.request(readSingleton('global')),
  directus.request(
    readItems('posts', {
      fields: ['slug', 'title', 'description', 'published_date', 'image', { author: ['name'] }] as unknown as ['*'],
      filter: { status: { _eq: 'published' } },
      sort: ['-published_date'],
      limit: MAX_POSTS,
    })
  ),
])
---

<BaseLayout title={global.title ?? siteConfig.title}>
  <TitlePage title={global.title ?? siteConfig.title} />
  <div class='hidden md:block'>
    <ListCategories />
  </div>

  <div>
    <h2 class='text-lg font-medium tracking-wide text-end'>Últimas Publicações</h2>
    <ListPosts FirstBig={true} posts={posts} />
  </div>
</BaseLayout>

<script>
  import { animate } from 'motion'
  const showAnimations = localStorage.getItem('animations') === 'true'

  if (showAnimations) {
    animate(
      '.title',
      { y: [80, 0], opacity: [0, 1] },
      {
        duration: 2.5,
        opacity: { duration: 3 },
        offset: [0, 0.55, 0.75]
      }
    )
  }
</script>
